# 必填三项
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
NOTION_TOKEN=your_notion_integration_token
IDEA_NOTION_DATABASE_ID=your_notion_database_id

# 以下全部可选。默认按「属性类型」自动认列：标题=唯一 title 列，
# 状态=单选列，分类=多选列，链接=URL 列。中英文库、随便改列名都能用。
# 只有在自动认错时（比如库里有两个单选列）才需要手动指定下面这些。
# IDEA_TITLE_PROPERTY=想法
# IDEA_STATUS_PROPERTY=状态
# IDEA_CATEGORY_PROPERTY=分类
# IDEA_URL_PROPERTY=链接
# IDEA_DEFAULT_STATUS=            # 不设=取状态列第一个选项
# IDEA_DEFAULT_CATEGORY=          # 不设=留空，事后自己标
# IDEA_MAX_TITLE_LENGTH=60
